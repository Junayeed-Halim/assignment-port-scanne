(import socket) Tj
1 0 0 1 54 572 Tm
(import sys) Tj
1 0 0 1 54 550 Tm
(# The ports we need to scan \(as required by the assignment\)) Tj
1 0 0 1 54 539 Tm
(ports = [80, 443, 22, 25, 53]) Tj
1 0 0 1 54 517 Tm
(# Check that the user provided an IP address as a command-line argument) Tj
1 0 0 1 54 506 Tm
(if len\(sys.argv\) != 2:) Tj
1 0 0 1 54 495 Tm
(    print\("Usage: python port_scanner.py <IP address>"\)) Tj
1 0 0 1 54 484 Tm
(    sys.exit\(1\)) Tj
1 0 0 1 54 462 Tm
(ip_address = sys.argv[1]) Tj
1 0 0 1 54 440 Tm
(print\(f"Scanning {ip_address}..."\)) Tj
1 0 0 1 54 429 Tm
(print\("-" * 30\)) Tj
1 0 0 1 54 407 Tm
(for port in ports:) Tj
1 0 0 1 54 396 Tm
(    try:) Tj
1 0 0 1 54 385 Tm
(        # Create a new socket for each port) Tj
1 0 0 1 54 374 Tm
(        sock = socket.socket\(socket.AF_INET, socket.SOCK_STREAM\)) Tj
1 0 0 1 54 352 Tm
(        # Set timeout to 100ms \(0.1 seconds\)) Tj
1 0 0 1 54 341 Tm
(        sock.settimeout\(0.1\)) Tj
1 0 0 1 54 319 Tm
(        # Try to connect; success means the port is open) Tj
1 0 0 1 54 308 Tm
(        sock.connect\(\(ip_address, port\)\)) Tj
1 0 0 1 54 297 Tm
(            print\(f"Port {port} is OPEN"\)) Tj
1 0 0 1 54 275 Tm
(    except Exception as e:) Tj
1 0 0 1 54 264 Tm
(        # Connection failed — report exception) Tj
1 0 0 1 54 253 Tm
(        print\(f"Port {port} is CLOSED \(exception: {e}\)"\)) Tj
1 0 0 1 54 242 Tm
(    finally:) Tj
1 0 0 1 54 231 Tm
(        try:) Tj
1 0 0 1 54 220 Tm
(            sock.close\(\)) Tj
1 0 0 1 54 209 Tm
(        except Exception:) Tj
1 0 0 1 54 198 Tm
(            pass) Tj
/F2 14 Tf
1 0 0 1 54 176 Tm
